# .dockerignore

# Git files
.git
.gitignore
.gitattributes
.github/

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# Build outputs
target/
build/
dist/
out/
bin/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Dependency directories
node_modules/
jspm_packages/

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# OS files
.DS_Store
Thumbs.db

# Documentation
docs/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Test files (but keep them in source for reference)
# These are excluded to keep image size small
src/test/
**/*.test.js
**/*.spec.js
**/*.test.ts
**/*.spec.ts

# Optional: Exclude large files that aren't needed for build
# but keep the Maven wrapper and source code!